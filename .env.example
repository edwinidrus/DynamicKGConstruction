# =============================================================================
# DynamicKGConstruction - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values before running docker compose.
#   cp .env.example .env

# -- Neo4j Configuration ------------------------------------------------------
# Neo4j runs WITHOUT authentication for local development (GraphRAG-ready setup).
# If you enable auth later, set NEO4J_AUTH=neo4j/<password> here.
NEO4J_AUTH=none
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# -- Neo4j Memory Settings ----------------------------------------------------
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE=256m

# -- SKGB Pipeline (used by Python, not Docker) -------------------------------
# LLM_MODEL=qwen2.5:32b
# EMBEDDINGS_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://localhost:11434

# -- Retrieval Pipeline (used by Python and Jupyter) --------------------------
# For local Docker access from the Jupyter container, Compose will override
# NEO4J_URI with JUPYTER_NEO4J_URI.
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j
NEO4J_VECTOR_INDEX=chunkEmbeddings

# Optional if you later use hybrid retrieval
# NEO4J_FULLTEXT_INDEX=chunkFulltext

# Ollama Cloud
OLLAMA_API_URL=https://ollama.com/api
OLLAMA_HOST=https://ollama.com
OLLAMA_API_KEY=replace-me
OLLAMA_LLM_MODEL=gemma4:31b-cloud
OLLAMA_EMBEDDINGS_MODEL=nomic-embed-text-v2-moe:latest

# Retrieval defaults
RETRIEVER_TOP_K=5
LLM_TEMPERATURE=0.0
RESPONSE_FALLBACK=I cannot answer this question because no relevant graph context was retrieved.

# Graph traversal defaults
CHUNK_TO_DOCUMENT_RELATIONSHIP=FROM_DOCUMENT
ENTITY_TO_CHUNK_RELATIONSHIP=FROM_CHUNK

# -- Jupyter Notebook Service -------------------------------------------------
JUPYTER_PORT=8888
JUPYTER_TOKEN=skgb
JUPYTER_NEO4J_URI=neo4j://neo4j:7687
