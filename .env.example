# =============================================================================
# DynamicKGConstruction - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values before running docker compose.
#   cp .env.example .env

# -- Neo4j Configuration ------------------------------------------------------
# Neo4j runs WITHOUT authentication for local development (GraphRAG-ready setup).
# If you enable auth later, set NEO4J_AUTH=neo4j/<password> here.
NEO4J_AUTH=none
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# -- Neo4j Memory Settings ----------------------------------------------------
NEO4J_HEAP_INITIAL=512m
NEO4J_HEAP_MAX=1G
NEO4J_PAGECACHE=256m

# -- SKGB Pipeline (used by Python, not Docker) -------------------------------
# LLM_MODEL=qwen2.5:32b
# EMBEDDINGS_MODEL=nomic-embed-text
# OLLAMA_BASE_URL=http://localhost:11434