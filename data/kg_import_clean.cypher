    |   2900 |  15.79 |       30.63 | 0      | 336    | CSMAR    |\n|                      | DT         |   2900 |   0.8  |        1.17 | 0      |   4.94 | AFR      |'], r.t_start = null, r.edge_row = 8;
MATCH (s:KGEntity {id: 'table_1_descriptive_statistics'}), (t:KGEntity {id: 'fdr_fdr_indicator'})
MERGE (s)-[r:INCLUDES]->(t)
