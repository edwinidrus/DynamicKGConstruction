CREATE CONSTRAINT kgentity_id IF NOT EXISTS
FOR (n:KGEntity) REQUIRE n.id IS UNIQUE;
CREATE INDEX kgentity_name IF NOT EXISTS
FOR (n:KGEntity) ON (n.name);
CREATE INDEX kgentity_category IF NOT EXISTS
FOR (n:KGEntity) ON (n.category);
CREATE INDEX missing_edge_row IF NOT EXISTS
FOR (n:MissingEndpoint) ON (n.edge_row);

