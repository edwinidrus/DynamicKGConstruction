FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /workspace

COPY skgb/retrieval/requirements.txt /tmp/retrieval-requirements.txt

RUN python -m pip install --upgrade pip \
    && python -m pip install jupyterlab ipykernel pandas \
    && python -m pip install -r /tmp/retrieval-requirements.txt

EXPOSE 8888
